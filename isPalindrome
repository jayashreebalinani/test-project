var isPalindrome = function(s) {

    var left = 0
    let cleaned = s.replace(/[^a-z0-9]/gi, "").toLowerCase();
    var right = cleaned.length - 1;

    while(left < right)
    {
        if(cleaned[left] != cleaned[right])
        {
            return false;
        }
        left++;
        right--;
    }
    return true;
    
};
